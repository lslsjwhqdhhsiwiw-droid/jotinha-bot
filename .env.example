# ─── OBRIGATÓRIO ────────────────────────────────────────
# Token do seu bot no Discord Developer Portal
DISCORD_TOKEN=seu_token_aqui

# URL do banco de dados PostgreSQL
# No Railway: adicione o plugin "PostgreSQL" e a variável DATABASE_URL é criada automaticamente
# Com Neon (externo): cole a URL do painel do Neon aqui
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ─── OPCIONAL ────────────────────────────────────────────
# Chave da API OpenAI (para funcionalidades de IA avançada)
OPENAI_API_KEY=sua_chave_openai_aqui
